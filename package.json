{
  "name": "ideaia-agent",
  "version": "0.1.0",
  "description": "RAG runtime agent for IDEA IA clients — reads KB from Postgres+pgvector, responds via GHL through n8n",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "bash db/migrate.sh",
    "db:seed:petro": "bash db/seed-petro.sh",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "test:conversation": "node scripts/test-conversation.js",
    "embed:batch": "node scripts/embed-batch.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "dotenv": "^16.4.5",
    "openai": "^4.67.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
