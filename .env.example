# ====================================================================
# IDEA IA — Agent RAG Runtime · variables de entorno
# ====================================================================
# Copiar este archivo a .env y completar con valores reales.
# NUNCA commitear el .env real al repositorio.
# ====================================================================

# --- Postgres (Knowledge Layer estructurado + pgvector) ---
# Self-hosted en Contabo via Easypanel
PG_HOST=
PG_PORT=5432
PG_DATABASE=ideaia_agent
PG_USER=
PG_PASSWORD=
# URL completa para n8n
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ideaia_agent

# --- Upstash Redis (Session Layer) ---
# Crear DB en upstash.com con dev-project@ideaia.app
REDIS_URL=
REDIS_TOKEN=

# --- OpenAI (LLM + Embeddings) ---
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (opcional — fallback si OpenAI no alcanza) ---
ANTHROPIC_API_KEY=
ANTHROPIC_LLM_MODEL=claude-haiku-4-5

# --- Google Sheets (lectura del KB Workbook) ---
# Mismo service account usado por el onboarding (con permiso de lectura en la Shared Drive)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# --- GHL (CRM + Calendar) ---
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=
GHL_API_BASE=https://services.leadconnectorhq.com

# --- n8n (instancia centralizada) ---
N8N_BASE_URL=
N8N_WEBHOOK_URL=
N8N_API_KEY=

# --- Notificaciones ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@ideaia.app
NOTIFY_INTERNAL_TO=dev-project@ideaia.app

# --- Cliente piloto ---
PILOT_CLIENT_ID=
PILOT_SHEET_ID=
PILOT_GHL_CALENDAR_ID=
